---
import DefaultLayout from "../layouts/DefaultLayout.astro";

const username = "mericxy";
const response = await fetch(`https://api.github.com/users/${username}/repos?sort=updated`);
const repos = await response.json();
---

<DefaultLayout title="Projects | Portfolio">
  <section class="space-y-6">
    <h1 class="text-3xl font-bold">Projects</h1>
    <p class="text-lg text-gray-700">
      Here are some of my most recent repositories from GitHub:
    </p>

    <ul class="grid sm:grid-cols-2 gap-4">
      {repos.slice(0, 6).map((repo: { html_url: string | URL | null | undefined; name: unknown; description: any; stargazers_count: unknown; forks_count: unknown; }) => (
        <li class="p-4 border rounded-xl shadow-sm hover:shadow-md transition hover:border-blue-600">
          <a href={repo.html_url} target="_blank" class="font-semibold text-blue-600 hover:text-blue-700 underline">
            {repo.name}
          </a>
          <p class="text-sm text-gray-600 mt-1">{repo.description || "No description available."}</p>
          <p class="text-xs text-gray-500 mt-2">⭐ {repo.stargazers_count} | Forks: {repo.forks_count}</p>
        </li>

      ))}
    </ul>
  </section>
</DefaultLayout>
