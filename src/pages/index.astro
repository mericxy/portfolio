---
import DefaultLayout from "../layouts/DefaultLayout.astro";
import Skills from "../components/Skills.astro";

const repos = [
  {
    html_url: "#",
    name: "Exemplo de Projeto 1",
    description: "Este é um projeto de exemplo para agilizar o desenvolvimento.",
  },
  {
    html_url: "#",
    name: "Exemplo de Projeto 2",
    description: "Este é outro projeto de exemplo para testar a exibição.",
  },
  {
    html_url: "#",
    name: "Exemplo de Projeto 3",
    description: "Um terceiro projeto de exemplo, sem conexão com a API.",
  },
  {
    html_url: "#",
    name: "Exemplo de Projeto 4",
    description: "Quarto e último projeto de exemplo temporário.",
  },
];
---

<DefaultLayout title="Home | Portfolio">
  <!-- Hero Section -->
  <section class="text-center my-12 space-y-4">
    <h1 class="text-4xl font-bold text-blue-600">Hi, I'm Márcio Éric</h1>
    <p class="text-lg text-gray-600 max-w-2xl mx-auto">
      Software Engineering student at UFAM-ICET, Frontend Developer at MOBA4AI,
      passionate about web and mobile development, AI, and DevOps.
    </p>
  </section>

  <!-- About Preview -->
  <section class="my-12 space-y-4">
    <h2 class="text-2xl font-bold">About Me</h2>
    <p class="text-gray-700">
      I am 24 years old and currently in the 9th semester of the Software Engineering
      program at UFAM-ICET. Member of NAVIR research group and developer at MOBA4AI,
      working with frontend, UI/UX, AI integrations, and DevOps.
    </p>
    <a href="/about/" class="text-blue-600 underline">Read more →</a>
  </section>

  <!-- Skills Preview -->
  <section class="my-12">
    <Skills />
    <a href="/about/" class="block mt-4 text-blue-600 underline">See full profile →</a>
  </section>

  <!-- Projects Preview -->
  <section class="my-12">
    <h2 class="text-2xl font-bold mb-4">Recent Projects</h2>
    <ul class="grid sm:grid-cols-2 gap-4">
      {repos.slice(0, 4).map((repo: { html_url: string | URL | null | undefined; name: unknown; description: any; }) => (
        <li class="p-4 border rounded-lg shadow-sm hover:shadow-md transition">
          <a href={repo.html_url} target="_blank" class="font-semibold text-blue-600 underline">
            {repo.name}
          </a>
          <p class="text-sm text-gray-600 mt-1">{repo.description || "No description available."}</p>
        </li>
      ))}
    </ul>
    <a href="/projects/"
		class="inline-block mt-4 text-blue-600 hover:text-blue-700 font-medium transition">
		View all projects →
	</a>

  </section>

  <!-- Contact Preview -->
  <section class="my-12 text-center">
    <h2 class="text-2xl font-bold">Get in Touch</h2>
    <p class="text-gray-700 mb-4">You can find me on:</p>
    <div class="space-x-6">
      <a href="https://github.com/mericxy" target="_blank" class="text-blue-600 underline">GitHub</a>
      <a href="https://www.linkedin.com/in/marcioericlvalente/" target="_blank" class="text-blue-600 underline">LinkedIn</a>
    </div>
    <a href="/contact/" class="block mt-4 text-blue-600 underline">More contact options →</a>
  </section>
</DefaultLayout>
